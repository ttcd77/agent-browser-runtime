{
  "name": "agent-browser-runtime",
  "version": "0.4.0",
  "description": "A local DevTools evidence runtime for AI agents. Single CLI surface (agent-browser); Personal Chrome and Managed Browser backends.",
  "type": "module",
  "license": "MIT",
  "private": false,
  "author": "ttcd77",
  "repository": {
    "type": "git",
    "url": "https://github.com/ttcd77/agent-browser-runtime.git"
  },
  "bugs": {
    "url": "https://github.com/ttcd77/agent-browser-runtime/issues"
  },
  "homepage": "https://github.com/ttcd77/agent-browser-runtime#readme",
  "keywords": [
    "ai-agent",
    "browser-automation",
    "chrome-devtools-protocol",
    "cdp",
    "devtools",
    "security-research",
    "playwright",
    "evidence",
    "appsec",
    "f12",
    "network-capture",
    "bug-bounty"
  ],
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "docs",
    "examples",
    "extension",
    "scripts",
    "README.md",
    "CONTRIBUTING.md",
    "LICENSE",
    "!**/*.test.mjs",
    "!**/*.test.js",
    "!**/*.test.ts",
    "!**/*.test.d.ts",
    "!**/*.test.js.map",
    "!**/*.test.d.ts.map",
    "!**/__fixtures__/**",
    "!scripts/lib/openclaw-shim/**",
    "!scripts/lib/hub-client/**",
    "!research/**",
    "!feedback/**",
    "!tmp/**",
    "!logs/**"
  ],
  "bin": {
    "agent-browser": "./scripts/agent-browser-cli.mjs",
    "agent-browser-research-pack": "./scripts/security-research-pack-cli.mjs"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-plugin-manifests.mjs",
    "test": "vitest run",
    "test:schemas": "vitest run src/plugins/cdp-traffic-capture/schemas.test.ts",
    "smoke:product": "npm run build && node scripts/product-smoke.mjs",
    "smoke:browser": "npm run build && node scripts/live-browser-smoke.mjs",
    "agent:server": "npm run build && node scripts/agent-cdp-server.mjs",
    "personal:browser": "node scripts/launch-personal-browser.mjs",
    "personal:chrome": "node scripts/personal-chrome-bridge.mjs",
    "smoke:personal": "node scripts/personal-chrome-smoke.mjs",
    "contract:devtools": "node scripts/devtools-contract-check.mjs",
    "smoke:server": "npm run build && node scripts/agent-server-smoke.mjs",
    "smoke:worker": "npm run build && node scripts/browser-worker-smoke.mjs",
    "smoke:f12": "npm run build && node scripts/devtools-f12-smoke.mjs",
    "smoke:professional": "npm run build && node scripts/professional-appsec-smoke.mjs",
    "smoke:cli": "node scripts/research-pack-cli-smoke.mjs",
    "smoke:example": "node scripts/example-security-research-pack-smoke.mjs",
    "smoke:demo": "node scripts/demo-fixture-smoke.mjs",
    "professional:scorecard": "node scripts/professional-scorecard.mjs",
    "worker:doctor": "node scripts/browser-worker-doctor.mjs",
    "feedback:note": "node scripts/feedback-note.mjs",
    "smoke:feedback": "node scripts/feedback-note-smoke.mjs",
    "smoke:agent-browser-cli": "node scripts/agent-browser-cli-smoke.mjs",
    "smoke:raw": "node scripts/raw-request-smoke.mjs",
    "smoke:agentic-burp": "node scripts/agentic-burp-workflow-smoke.mjs",
    "research:pack": "node scripts/security-research-pack-cli.mjs",
    "check": "npm run build && npm run test && npm run smoke:cli && npm run smoke:feedback && npm run smoke:agentic-burp && npm run smoke:raw",
    "check:smoke:agent-browser-cli": "node scripts/agent-browser-cli-smoke.mjs",
    "check:devtools": "npm run contract:devtools && npm run smoke:f12 && npm run smoke:personal && npm run smoke:professional",
    "check:professional": "npm run check && npm run smoke:server && npm run contract:devtools && npm run smoke:f12 && npm run smoke:professional && npm run smoke:example && npm run professional:scorecard",
    "check:full": "npm run check && npm run check:devtools",
    "lint": "eslint scripts/lib/",
    "release:readiness": "node scripts/open-source-readiness.mjs",
    "check:release": "npm run release:readiness && npm run check:full"
  },
  "optionalDependencies": {
    "@rolldown/binding-darwin-arm64": "1.0.1",
    "@rolldown/binding-darwin-x64": "1.0.1",
    "@rolldown/binding-linux-x64-gnu": "1.0.1",
    "@rolldown/binding-win32-x64-msvc": "1.0.1"
  },
  "dependencies": {
    "chrome-remote-interface": "^0.34.0",
    "dns-packet": "^5.6.1",
    "ws": "^8.21.0",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.13.1",
    "eslint": "^10.4.1",
    "typescript": "^5.7.3",
    "vitest": "^4.1.5"
  }
}
