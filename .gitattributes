# Default: normalise line endings on commit, checkout per-platform
* text=auto

# Unix scripts — must be LF so shebang works on Linux/macOS
*.sh  text eol=lf
*.mjs text eol=lf
*.js  text eol=lf
*.ts  text eol=lf
*.json text eol=lf
*.md  text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Windows scripts — keep CRLF
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files — do not mangle
*.png  binary
*.jpg  binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
